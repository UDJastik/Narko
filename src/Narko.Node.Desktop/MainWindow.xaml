<Window x:Class="Narko.Node.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Narko Node (Scaffold)" Height="560" Width="900" MinHeight="480" MinWidth="760"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Narko Node" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="OpenClaw-like Windows desktop node scaffold" Foreground="#666"/>
        </StackPanel>

        <Border Grid.Row="1" Padding="12" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Node status" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock x:Name="StatusText" Text="Idle (scaffold mode)"/>
                <TextBlock x:Name="HeartbeatText" Text="Last heartbeat: never" Foreground="#666"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="12" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="Planned features" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="• Node registration and auth handshake" Margin="0,0,0,4"/>
                    <TextBlock Text="• Secure command execution sandbox" Margin="0,0,0,4"/>
                    <TextBlock Text="• Browser relay bridge" Margin="0,0,0,4"/>
                    <TextBlock Text="• Filesystem/task orchestration" Margin="0,0,0,4"/>
                    <TextBlock Text="• Notifications + telemetry" Margin="0,0,0,4"/>
                    <TextBlock Text="• Auto-update pipeline (placeholder only)" Margin="0,0,0,4"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="12" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Margin="6,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Logs" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox x:Name="LogBox" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/>
                </DockPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="120" Margin="0,0,8,0" Click="SimulateConnect_Click">Simulate connect</Button>
            <Button Width="120" Margin="0,0,8,0" Click="CheckUpdate_Click">Check update</Button>
            <Button Width="120" Click="Exit_Click">Exit</Button>
        </StackPanel>
    </Grid>
</Window>
