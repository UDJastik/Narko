<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Narko Node"
    Manufacturer="UDJastik"
    Version="0.1.0"
    UpgradeCode="A395F0AE-EB28-4C10-B93A-3164B3D4A3D7"
    Scope="perMachine"
    InstallerVersion="500"
    Language="1033">

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Narko Node" />
    </StandardDirectory>

    <Feature Id="MainFeature" Title="Narko Node" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
  </Package>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="*">
        <File Id="NarkoNodeDesktopExe" Source="$(var.PublishDir)\Narko.Node.Desktop.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
